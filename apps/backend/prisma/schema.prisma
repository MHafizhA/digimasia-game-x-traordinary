generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String       @id @default(cuid())
  name             String
  pin              String       @unique
  division         String
  isAdmin          Boolean      @default(false)
  isJoined         Boolean      @default(false)
  collectedWater   Int          @default(0)
  contributedWater Int          @default(0)
  score            Int          @default(0)
  createdAt        DateTime     @default(now())
  answers          UserAnswer[]
  votes            Vote[]
}

model Session {
  id           String    @id @default("singleton")
  phase        String    @default("LOGIN")
  currentQ     Int       @default(0)
  totalWater   Int       @default(0)
  treeStage    Int       @default(0)
  phaseStartAt DateTime?
  updatedAt    DateTime  @updatedAt
}

model Candidate {
  id       String @id
  name     String
  division String
  type     String
  imageUrl String
  votes    Vote[]
}

model Vote {
  id          String    @id @default(cuid())
  userId      String
  candidateId String
  category    String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, category])
}

model Question {
  id      String       @id @default(cuid())
  index   Int          @unique
  text    String
  options String
  answer  Int
  answers UserAnswer[]
}

model UserAnswer {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  selected   Int?
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, questionId])
}
